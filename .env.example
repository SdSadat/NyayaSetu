# =============================================================================
# NyayaSetu Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- AWS Configuration ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Amazon Nova LLM (Bedrock) ---
AWS_NOVA_MODEL_ID=us.amazon.nova-lite-v1:0
AWS_NOVA_TIMEOUT_MS=240000

# --- Amazon Nova Embeddings (Bedrock) ---
AWS_NOVA_EMBEDDING_MODEL_ID=amazon.nova-2-multimodal-embeddings-v1:0
AWS_NOVA_EMBEDDING_DIMENSION=1024
AWS_NOVA_EMBEDDING_REGION=us-east-1

# --- Bedrock Knowledge Bases (vector retrieval — AWS-native) ---
# Set this to your Knowledge Base ID to use Bedrock KB for retrieval.
# If blank, falls back to ChromaDB (local dev).
BEDROCK_KB_ID=

# --- DynamoDB ---
# Leave blank to run stateless (frontend localStorage only)
DYNAMODB_TABLE_NAME=NyayaSetu-DrishtiHistory
DYNAMODB_USERS_TABLE=NyayaSetu-Users
DYNAMODB_PROGRESS_TABLE=NyayaSetu-UserProgress
DYNAMODB_HISTORY_TTL_DAYS=30

# --- Authentication ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- ChromaDB (local dev fallback for vector storage) ---
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=legal_chunks

# --- Application ---
NODE_ENV=development
API_PORT=3029
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5183

# --- Safety Thresholds ---
SAFETY_CERTAINTY_THRESHOLD=0.8
SAFETY_MAX_RETRIEVAL_RESULTS=10
SAFETY_REFUSE_ON_NO_SOURCE=true
