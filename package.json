{
  "name": "nyayasetu",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered legal information and public legal education platform for India",
  "author": "NyayaSetu Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare:all": "tsx scripts/prepare-all.ts",
    "ingest:all": "tsx scripts/ingest-all.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1007.0",
    "@aws-sdk/client-dynamodb": "^3.1007.0",
    "@aws-sdk/lib-dynamodb": "^3.1007.0"
  }
}
