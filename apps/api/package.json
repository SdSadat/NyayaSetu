{
  "name": "@nyayasetu/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "ingest": "tsx src/cli/ingest-bare-act.ts",
    "ingest:prepared": "tsx src/cli/ingest-prepared.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1007.0",
    "@aws-sdk/client-dynamodb": "^3.1007.0",
    "@aws-sdk/lib-dynamodb": "^3.1007.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.0",
    "@nyayasetu/jurisdiction": "workspace:*",
    "@nyayasetu/legal-rag": "workspace:*",
    "@nyayasetu/prompts": "workspace:*",
    "@nyayasetu/safety-layer": "workspace:*",
    "@nyayasetu/shared-types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.1.0",
    "mammoth": "^1.11.0",
    "nanoid": "^5.1.6",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.0",
    "pino-pretty": "^10.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
